generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Song {
  id           String   @id @default(cuid())
  title        String
  artist       String   @default("Unknown")
  album        String   @default("")
  duration     Float    @default(0)
  genre        String   @default("")
  filePath     String   @default("")
  coverUrl     String   @default("")
  lyricsLrc    String   @default("")
  lyricsJson   String   @default("[]")
  playCount    Int      @default(0)
  audioBase64  String   @default("")
  coverBase64  String   @default("")
  mimeType     String   @default("audio/mpeg")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([title])
  @@index([artist])
  @@index([genre])
  @@index([createdAt])
}

model AdminConfig {
  id        String @id @default("main")
  password  String
  updatedAt DateTime @updatedAt
}
